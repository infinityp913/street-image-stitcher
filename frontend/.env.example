# Vercel Blob — get from Vercel dashboard → Storage → your blob store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# URL of the Railway backend (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app

# Secret for the /api/cron route — set the same value in Vercel cron headers
CRON_SECRET=your-cron-secret-here
