# Gemini API key — get from Google AI Studio
GEMINI_API_KEY=AIza...

# Vercel Blob token — same value as frontend, used to upload result PNGs
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Comma-separated allowed origins (your Vercel deployment URL)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
